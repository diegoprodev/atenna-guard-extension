{
  "name": "Atenna — Checkout Recovery + Onboarding",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "asaas-checkout-events",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "bb1c1234-0001-0001-0001-000000000001",
      "name": "Webhook Asaas",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300],
      "webhookId": "atenna-asaas-checkout"
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.event }}",
              "operation": "equal",
              "value2": "CHECKOUT_CREATED"
            }
          ]
        }
      },
      "id": "bb1c1234-0002-0002-0002-000000000002",
      "name": "Foi CHECKOUT_CREATED?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [460, 200]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.event }}",
              "operation": "equal",
              "value2": "CHECKOUT_PAID"
            }
          ]
        }
      },
      "id": "bb1c1234-0003-0003-0003-000000000003",
      "name": "Foi CHECKOUT_PAID?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [460, 400]
    },
    {
      "parameters": {
        "amount": 2,
        "unit": "hours"
      },
      "id": "bb1c1234-0004-0004-0004-000000000004",
      "name": "Aguardar 2h",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [700, 120]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT event_type FROM checkout_events WHERE checkout_id = '{{ $('Webhook Asaas').item.json.checkout.id }}' AND event_type = 'paid' LIMIT 1",
        "additionalFields": {}
      },
