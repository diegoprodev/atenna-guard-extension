        "text": "",
        "html": "<html><body style=\"font-family:sans-serif;background:#0f0f0f;color:#e8e8e8;padding:40px\"><div style=\"max-width:560px;margin:0 auto\"><h2 style=\"font-weight:600;font-size:20px\">Oi, {{ $('Webhook Asaas').item.json.checkout.customer.name }}</h2><p style=\"color:#aaa;line-height:1.7\">Vimos que voce iniciou a assinatura do Atenna Pro mas nao concluiu.</p><p style=\"color:#aaa;line-height:1.7\"><strong>O que te impediu de assinar?</strong></p><a href=\"https://atennaplugin.maestro-n8n.site/checkout/survey?reason=price\" style=\"display:inline-block;margin:4px;padding:10px 20px;background:#1f1f1f;border:1px solid #333;border-radius:6px;color:#e8e8e8;text-decoration:none;font-size:13px\">Preco alto</a> <a href=\"https://atennaplugin.maestro-n8n.site/checkout/survey?reason=not_now\" style=\"display:inline-block;margin:4px;padding:10px 20px;background:#1f1f1f;border:1px solid #333;border-radius:6px;color:#e8e8e8;text-decoration:none;font-size:13px\">Nao e o momento</a></div></body></html>",
        "options": {}
