# Gemini API — Primary LLM for Prompt Generation
# Get your key from: https://ai.google.dev/
# Free tier: 60 requests/min
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API — Intelligent Fallback LLM (gpt-4o-mini)
# Get your key from: https://platform.openai.com/api-keys
# Cost: $0.15 per 1M input tokens / $0.60 per 1M output tokens
# Most cost-effective modern model, 10-20x cheaper than full gpt-4
OPENAI_API_KEY=your_openai_api_key_here

# DLP Backend Configuration
DLP_BACKEND_URL=https://atennaplugin.maestro-n8n.site

# Database (FastAPI)
DATABASE_URL=sqlite:///./test.db

# CORS Origins
CORS_ORIGINS=["https://www.google.com","https://claude.ai"]
